                      class="mil-scale-img"
                      data-value-1="1"
                      data-value-2="1.15"
                    />
                  </div>
                  <div class="mil-tac">
                    <h3 class="mil-fs20 mil-mb15 mil-up">
                      Nghệ sĩ nhiếp ảnh<br />Lê Công Quốc Cường
                    </h3>
                    <p class="mil-up">Giám đốc hình ảnh</p>
                  </div>
                </div>
              </div>
              <div class="col-lg-4">
                <div class="mil-team-card mil-mb90">
                  <div class="mil-portrait mil-mb60 mil-992-mb30 mil-up">
                    <img
                      src="/wings-innovation-hub/public/img/about/team/2.jpg"
                      alt="member"
                      class="mil-scale-img"
                      data-value-1="1"
                      data-value-2="1.15"
                    />
                  </div>
                  <div class="mil-tac">
                    <h3 class="mil-fs20 mil-mb15 mil-up">Đào Hằng</h3>
                    <p class="mil-up">Projects Manager</p>
                  </div>
                </div>
              </div>
              <div class="col-lg-4">
                <div class="mil-team-card mil-mb90">
                  <div class="mil-portrait mil-mb60 mil-992-mb30 mil-up">
                    <img
                      src="/wings-innovation-hub/public/img/about/team/3.jpg"
                      alt="member"
                      class="mil-scale-img"
                      data-value-1="1"
                      data-value-2="1.15"
                    />
                  </div>
                  <div class="mil-tac">
                    <h3 class="mil-fs20 mil-mb15 mil-up">Thịnh Nguyễn</h3>
                    <p class="mil-up">Giám đốc Marketing</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- team end -->
        <!-- call to action -->
        <div class="mil-soft-section mil-up mil-p-180-120">
          <div class="container">
            <div class="row mil-jcb mil-aic">
              <div class="col-lg-6 mil-mb60">
                <h2 class="mil-fs68 mil-light mil-up">
                  Start your next <br />project
                  <a
                    href="contact.html"
                    class="mil-text-link mil-accent mil-c-gone"
                    >now</a
