        <div class="mil-p-120-30">
          <div class="container">
            <div class="mil-tac">
              <h2 class="mil-fs42 mil-mb90 mil-up">Meet the Collaborators</h2>
            </div>
            <div class="row mil-aic mil-jcb">
              <div class="col-lg-4">
                <div class="mil-team-card mil-mb90">
                  <div class="mil-portrait mil-mb60 mil-992-mb30 mil-up">
                    <img
