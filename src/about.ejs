<!doctype html>
<html lang="en-US">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="HandheldFriendly" content="true" />
    <meta name="author" content="bslthemes" />

    <!-- grid css -->
    <link
      rel="stylesheet"
      href="/wings-innovation-hub/public/css/plugins/bootstrap-grid.css"
    />
    <!-- font awesome css -->
    <link
      rel="stylesheet"
      href="/wings-innovation-hub/public/fonts/css/font-awesome.min.css"
    />

    <!-- swiper css -->
    <link
      rel="stylesheet"
      href="/wings-innovation-hub/public/css/plugins/swiper.min.css"
    />
    <!-- <link rel="stylesheet" href="css/plugins/swiper-bundle.min.css" /> -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/swiper/swiper-bundle.min.css"
    />
    <!-- okai css -->
    <link rel="stylesheet" href="/wings-innovation-hub/public/css/style.css" />
    <!-- page title -->
    <title>Wings Innovation Hub</title>

    <!-- Favicon -->
    <link
      rel="shortcut icon"
      href="/wings-innovation-hub/public/img/logos/logoweb.webp"
      type="image/x-icon"
    />
    <link
      rel="icon"
      href="/wings-innovation-hub/public/img/logos/logoweb.webp"
      type="image/x-icon"
    />
  </head>
  <body>
    <!-- wrapper -->
    <div id="smooth-wrapper" class="mil-page-wrapper">
      <!-- cursor -->
      <div class="mil-cursor-follower"></div>
      <!-- cursor end -->

      <!-- scroll progress -->
      <div class="mil-progress-track">
        <div class="mil-progress"></div>
      </div>
      <!-- scroll progress end -->

      <!-- top panel & menu -->
      <%- include('partials/header') %>
      <!-- top panel & menu end -->

      <!-- content -->
      <div id="smooth-content" class="mil-content">
        <!-- banner -->
        <div class="mil-banner-inner">
          <div class="container">
            <div class="mil-banner-text">
              <div>
                <h1 class="mil-fs68 mil-mb30">About Wings</h1>
                <ul class="mil-breadcrumbs">
                  <li>
                    <a href="index.html" class="mil-c-gone">Home</a>
                  </li>
                  <li>
                    <a href="home-1.html" class="mil-c-gone">Pages</a>
                  </li>
                  <li>
                    <a href="about.html" class="mil-c-gone">About us</a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
          <div class="mil-banner-img">
            <img
              src="/wings-innovation-hub/public/img/about/hinh dau tien.webp"
              alt="banner"
              class="mil-scale-img"
              data-value-1="1"
              data-value-2="1.1"
            />
          </div>
        </div>
        <!-- banner end -->
        <!-- experience -->
        <div class="">
          <div class="container">
            <div class="row mil-jcb">
              <div class="col-lg-12">
                <div class="mil-exp-box mil-type-2 mil-up">
                  <div class="mil-exp-content mil-up">
                    <div class="mil-exp-number">20<span>+</span></div>
                    <h2 class="mil-exp-text mil-fs42">
                      Năm kinh nghiệm trong truyền thông, văn hoá và nội dung
                    </h2>
                  </div>
                </div>
              </div>
              <!-- <div class="col-lg-5"></div> -->
            </div>
          </div>
          <div class="container mil-p-120-120">
            <div class="row">
              <div class="col-lg-2"></div>
              <div class="col-lg-8">
                <p class="mil-text mil-fs30 mil-light mil-up">
                  Wings Innovation Hub được phát triển từ Truyền thông Đôi Cánh,
                  kế thừa hơn 20 năm kinh nghiệm trong truyền thông, nghệ thuật,
                  văn hoá và sản xuất nội dung.
                </p>
              </div>
            </div>
          </div>
        </div>
        <!-- experience end -->
        <!-- about -->
        <div class="mil-about">
          <div class="container">
            <div class="row flex-sm-row-reverse mil-jcb mil-aic">
              <div class="col-lg-5 mil-relative">
                <div class="mil-about-text">
                  <span class="mil-suptitle mil-accent mil-mb30 mil-up"
                    >About Wings</span
                  >
                  <h2 class="mil-fs42 mil-mb30 mil-up">
                    Kết nối chiều sâu văn hoá với tư duy hệ sinh thái
                  </h2>
                  <p class="mil-text mil-fs16 mil-light mil-mb30 mil-up">
                    Chúng tôi kể chuyện, kiến tạo trải nghiệm và kết nối con
                    người, từ đó xây dựng giá trị bền vững và ảnh hưởng dài hạn
                    cho thương hiệu, tổ chức và cộng đồng.
                  </p>
                  <div class="mil-up">
                    <a href="#." class="mil-btn mil-btn-border mil-c-gone"
                      >Làm việc cùng Wings</a
                    >
                  </div>
                </div>
              </div>
              <div class="col-lg-7 mil-about-image-frame">
                <div class="mil-about-img mil-up">
                  <img
                    src="/wings-innovation-hub/public/img/about/5.jpg"
                    alt="banner"
                    class="mil-scale-img"
                    data-value-1="1"
                    data-value-2="1.25"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- about end -->
        <!-- services -->
        <%- include('partials/services') %>
        <!-- services end -->
        <!-- reviews -->
        <div class="mil-p-0-120">
          <div class="container">
            <div class="row mil-jcc">
              <div class="col-lg-8">
                <div class="swiper-container mil-reviews-slider mil-c-swipe">
                  <div class="swiper-wrapper">
                    <div class="swiper-slide">
                      <div
                        class="mil-review"
                        data-swiper-parallax="20%"
                        data-swiper-parallax-scale="0.5"
                        data-swiper-parallax-opacity="0"
                      >
                        <div class="mil-user mil-mb60 mil-up">
                          <img
                            src="/wings-innovation-hub/public/img/faces/1.jpg"
                            alt="user"
                          />
                        </div>
                        <p
                          class="mil-text mil-fs30 mil-light mil-tac mil-mb60 mil-up"
                        >
                          Nhà báo, đạo diễn và nhà sản xuất nội dung với hơn 20
                          năm kinh nghiệm trong lĩnh vực truyền thông, văn hoá
                          và tổ chức sự kiện.
                        </p>
                        <h6 class="mil-fs18 mil-mb15 mil-up">
                          Nguyễn Yến Trinh
                        </h6>
                        <div class="mil-up">Founder</div>
                      </div>
                    </div>
                    <div class="swiper-slide">
                      <div
                        class="mil-review"
                        data-swiper-parallax="20%"
                        data-swiper-parallax-scale="0.5"
                        data-swiper-parallax-opacity="0"
                      >
                        <div class="mil-user mil-mb60 mil-up">
                          <img
                            src="/wings-innovation-hub/public/img/faces/2.jpg"
                            alt="user"
                          />
                        </div>
                        <p
                          class="mil-text mil-fs30 mil-light mil-tac mil-mb60 mil-up"
                        >
                          Kinh nghiệm tổ chức, biên tập các sự kiện âm nhạc nghệ
                          thuật tại Việt Nam và nhiều nước trên thế giới.
                        </p>
                        <h6 class="mil-fs18 mil-mb15 mil-up">
                          Nguyễn Tài Anh (Nghệ sĩ Quang Thành)
                        </h6>
                        <div class="mil-up">Giám đốc Phát triển Quốc tế</div>
                      </div>
                    </div>
                    <div class="swiper-slide">
                      <div
                        class="mil-review"
                        data-swiper-parallax="20%"
                        data-swiper-parallax-scale="0.5"
                        data-swiper-parallax-opacity="0"
                      >
                        <div class="mil-user mil-mb60 mil-up">
                          <img
                            src="/wings-innovation-hub/public/img/faces/3.jpg"
                            alt="user"
                          />
                        </div>
                        <p
                          class="mil-text mil-fs30 mil-light mil-tac mil-mb60 mil-up"
                        >
                          Giám khảo Phim truyện điện ảnh Cánh Diều Vàng năm
                          2020, năm 2022, năm 2024.<br />Giải thưởng Cánh diều
                          vàng biên kịch điện ảnh xuất sắc năm 2016, năm
                          2019.<br />Giải thưởng Cánh diều vàng biên kịch phim
                          truyền hình xuất sắc năm 2022.Giải Bông Sen vàng
                          2025.<br />Giải biên kịch xuất sắc nhất Liên hoan Phim
                          Châu Á<br />Đà Nẵng 2025.
                        </p>
                        <h6 class="mil-fs18 mil-mb15 mil-up">
                          Nguyễn Thị Ngọc Bích
                        </h6>
                        <div class="mil-up">Giám đốc sáng tạo</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-10 col-md-5 mil-relative">
                <div class="mil-reviews-nav mil-up">
                  <div class="mil-slider-btn mil-prev mil-c-gone">
                    <svg
                      width="28"
                      height="15"
                      viewBox="0 0 28 15"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
