                      <path
                        d="M1.25 8.74984H23.2325L19.1162 12.8661C18.6281 13.3542 18.6281 14.1455 19.1162 14.6336C19.3606 14.878 19.68 14.9998 20 14.9998C20.32 14.9998 20.6394 14.878 20.8838 14.6336L27.1338 8.38359C27.3681 8.14984 27.5 7.83172 27.5 7.49984C27.5 7.16797 27.3681 6.85047 27.1338 6.61609L20.8838 0.366094C20.3956 -0.122031 19.6044 -0.122031 19.1162 0.366094C18.6281 0.854219 18.6281 1.64547 19.1162 2.13359L23.2325 6.24984H1.25C0.56 6.24984 0 6.80984 0 7.49984C0 8.18984 0.56 8.74984 1.25 8.74984Z"
                        fill="black"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- reviews end -->
        <!-- call to action -->
        <div class="">
          <div class="container">
            <div class="mil-cta mil-up">
              <div class="row mil-aic">
                <div class="col-lg-8 mil-up">
                  <p class="mil-text mil-fs26 mil-light mil-mb30">
                    Tell more about your new business plan
                  </p>
                </div>
                <div class="col-lg-4 mil-jce mil-992-jcs mil-up">
                  <a href="#." class="mil-btn mil-btn-soft mil-mb30 mil-c-gone"
