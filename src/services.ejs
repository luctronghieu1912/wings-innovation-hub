              src="/wings-innovation-hub/public/img/banners/15.jpg"
              alt="banner"
              class="mil-scale-img"
              data-value-1=".90"
              data-value-2="1.11"
            />
          </div>
        </div>
        <!-- banner end -->
        <!-- services -->
        <%- include('partials/services') %>
        <!-- services end -->
        <!-- partners brands -->
        <%- include('partials/partners') %>
